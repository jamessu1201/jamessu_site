# Notion 同步設定 — 複製這個檔成 .env.local 再填值
# .env.local 已在 .gitignore,不會 commit

# 從 https://www.notion.so/my-integrations 建 integration 後拿到的 token
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 文章 database 的 ID(從 DB URL 抽,32 字元,可含 dash)
# 例:https://www.notion.so/your-name/abc123...?v=... → 取 abc123... 那段
NOTION_DATABASE_ID=00000000000000000000000000000000

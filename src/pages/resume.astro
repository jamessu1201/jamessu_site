<style is:global>
    .resume-root { color: var(--primary); }
    .resume-root .hidden { display: none !important; }

    .resume-header {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        align-items: flex-start;
        justify-content: space-between;
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--line-divider);
        margin-bottom: 1.5rem;
    }
    .resume-title h1 { font-size: 1.8rem; font-weight: 700; margin: 0 0 0.25rem; color: var(--text-strong); }
    .resume-meta { font-size: 0.9rem; color: var(--text-subtle); display: flex; flex-wrap: wrap; gap: 0.5rem; }
    .resume-meta a { color: var(--primary); text-decoration: underline; text-decoration-color: transparent; transition: text-decoration-color 0.15s; }
    .resume-meta a:hover { text-decoration-color: currentColor; }

    .resume-toolbar { display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap; }
    .lang-switch { display: inline-flex; background: var(--btn-regular-bg); border-radius: 9999px; padding: 0.25rem; }
    .lang-switch button {
        border: none;
        background: transparent;
        padding: 0.35rem 0.9rem;
        border-radius: 9999px;
        font-size: 0.875rem;
        cursor: pointer;
        color: var(--text-subtle);
        transition: all 0.15s;
    }
    .lang-switch button.active { background: var(--primary); color: white; }
    .pdf-link {
        font-size: 0.875rem;
        padding: 0.4rem 0.9rem;
        border-radius: 9999px;
        background: var(--btn-regular-bg);
        color: var(--text-subtle);
        text-decoration: none;
        transition: background 0.15s;
    }
    .pdf-link:hover { background: var(--btn-regular-bg-hover); }

    .resume-body h2 {
        font-size: 1.15rem;
        font-weight: 700;
        margin: 1.5rem 0 0.75rem;
        padding-bottom: 0.25rem;
        border-bottom: 1px solid var(--line-divider);
        color: var(--text-strong);
    }
    .resume-body h2:first-child { margin-top: 0; }

    .resume-body .entry { margin-bottom: 1rem; }
    .resume-body .entry-head {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: baseline;
        flex-wrap: wrap;
    }
    .resume-body .entry-head strong { color: var(--text-strong); font-size: 1rem; }
    .resume-body .entry-sub { font-size: 0.875rem; color: var(--text-subtle); margin-top: 0.1rem; }
    .resume-body .entry-time { text-align: right; font-size: 0.85rem; color: var(--text-subtle); white-space: nowrap; }

    .resume-body ul {
        list-style: disc;
        padding-left: 1.25rem;
        margin: 0.4rem 0 0.5rem;
        font-size: 0.925rem;
        line-height: 1.55;
    }
    .resume-body ul.skills { margin-top: 0; }
    .resume-body ul li { margin: 0.2rem 0; }
    .resume-body ul li strong { color: var(--text-strong); }
</style>

<script>
    function setResumeLang(lang: "zh" | "en") {
        document.querySelectorAll<HTMLElement>("[data-lang-section]").forEach(el => {
            el.classList.toggle("hidden", el.dataset.langSection !== lang);
        });
        document.querySelectorAll<HTMLElement>(".zh-only").forEach(el => {
            el.classList.toggle("hidden", lang !== "zh");
        });
        document.querySelectorAll<HTMLElement>(".en-only").forEach(el => {
            el.classList.toggle("hidden", lang !== "en");
        });
        document.querySelectorAll<HTMLButtonElement>(".lang-switch button").forEach(btn => {
            const active = btn.dataset.lang === lang;
            btn.classList.toggle("active", active);
            btn.setAttribute("aria-selected", String(active));
        });
        const zhPdf = document.querySelector<HTMLElement>("[data-pdf-zh]");
        const enPdf = document.querySelector<HTMLElement>("[data-pdf-en]");
        zhPdf?.classList.toggle("hidden", lang !== "zh");
        enPdf?.classList.toggle("hidden", lang !== "en");
    }

    function initResume() {
        document.querySelectorAll<HTMLButtonElement>(".lang-switch button").forEach(btn => {
            btn.addEventListener("click", () => {
                const lang = btn.dataset.lang as "zh" | "en";
                setResumeLang(lang);
            });
        });
    }

    initResume();
    document.addEventListener("swup:page:view", initResume);
</script>
